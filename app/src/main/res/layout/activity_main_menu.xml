<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#0D1A0D"
    android:padding="32dp">

    <!-- Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MOLE DIVER"
        android:textSize="40sp"
        android:textColor="#FFFFFF"
        android:fontFamily="monospace"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:layout_marginBottom="8dp" />

    <!-- Subtitle / best depth -->
    <TextView
        android:id="@+id/tvBestDepth"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DIG DEEP · OUT RUN THE GAS"
        android:textSize="11sp"
        android:textColor="#888888"
        android:fontFamily="monospace"
        android:letterSpacing="0.05"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/tvBestScore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BEST DEPTH: 0 ★"
        android:textSize="12sp"
        android:textColor="#F5C542"
        android:fontFamily="monospace"
        android:layout_marginBottom="48dp" />

    <!-- PLAY Button -->
    <Button
        android:id="@+id/btnPlay"
        android:layout_width="240dp"
        android:layout_height="52dp"
        android:text="PLAY"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:fontFamily="monospace"
        android:textStyle="bold"
        android:letterSpacing="0.15"
        android:backgroundTint="#2B6B2B"
        android:layout_marginBottom="12dp" />

    <!-- SHOP Button -->
    <Button
        android:id="@+id/btnShop"
        android:layout_width="240dp"
        android:layout_height="52dp"
        android:text="SHOP"
        android:textColor="#CCCCCC"
        android:textSize="16sp"
        android:fontFamily="monospace"
        android:textStyle="bold"
        android:letterSpacing="0.15"
        android:backgroundTint="#1A2E1A"
        android:layout_marginBottom="12dp" />

    <!-- COLLECTION Button -->
    <Button
        android:id="@+id/btnCollection"
        android:layout_width="240dp"
        android:layout_height="52dp"
        android:text="COLLECTION"
        android:textColor="#CCCCCC"
        android:textSize="16sp"
        android:fontFamily="monospace"
        android:textStyle="bold"
        android:letterSpacing="0.15"
        android:backgroundTint="#1A2E1A"
        android:layout_marginBottom="12dp" />

    <!-- OPTIONS Button -->
    <Button
        android:id="@+id/btnOptions"
        android:layout_width="240dp"
        android:layout_height="52dp"
        android:text="OPTIONS"
        android:textColor="#CCCCCC"
        android:textSize="16sp"
        android:fontFamily="monospace"
        android:textStyle="bold"
        android:letterSpacing="0.15"
        android:backgroundTint="#1A2E1A"
        android:layout_marginBottom="12dp" />

    <!-- ACHIEVEMENTS Button -->
    <Button
        android:id="@+id/btnAchievements"
        android:layout_width="240dp"
        android:layout_height="52dp"
        android:text="ACHIEVEMENTS"
        android:textColor="#CCCCCC"
        android:textSize="16sp"
        android:fontFamily="monospace"
        android:textStyle="bold"
        android:letterSpacing="0.15"
        android:backgroundTint="#1A2E1A" />

</LinearLayout>
