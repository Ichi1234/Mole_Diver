<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_upgrade_card"
    android:padding="14dp"
    android:layout_marginBottom="8dp">

    <!-- Name row + progress -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/tvSetName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#E0E0E0"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true" />

        <TextView
            android:id="@+id/tvSetProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#F5C542"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true" />

    </RelativeLayout>

    <!-- Description -->
    <TextView
        android:id="@+id/tvSetDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#555555"
        android:textSize="10sp"
        android:fontFamily="monospace"
        android:textStyle="italic"
        android:layout_marginBottom="8dp" />

    <!-- Item list (populated programmatically) -->
    <LinearLayout
        android:id="@+id/containerItems"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="8dp" />

    <!-- Reward line -->
    <TextView
        android:id="@+id/tvReward"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="10sp"
        android:fontFamily="monospace" />

</LinearLayout>
