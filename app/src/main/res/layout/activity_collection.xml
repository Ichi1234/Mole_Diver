<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D1A0D">

    <!-- Top bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#0a140a"
        android:paddingStart="8dp"
        android:paddingEnd="16dp">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BACK"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:backgroundTint="@android:color/transparent"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_centerInParent="true"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="COLLECTION"
                android:textSize="22sp"
                android:textColor="#4CAF50"
                android:fontFamily="monospace"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <TextView
                android:id="@+id/tvItemCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 / 50 COLLECTED"
                android:textSize="10sp"
                android:textColor="#666666"
                android:fontFamily="monospace" />

        </LinearLayout>

    </RelativeLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1E3A1E" />

    <!-- Tab buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:background="#0a140a">

        <Button
            android:id="@+id/btnTabItems"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="ITEMS"
            android:textColor="#4CAF50"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:backgroundTint="@android:color/transparent"
            android:stateListAnimator="@null" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#1E3A1E" />

        <Button
            android:id="@+id/btnTabSets"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="SETS"
            android:textColor="#888888"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:backgroundTint="@android:color/transparent"
            android:stateListAnimator="@null" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1E3A1E" />

    <!-- Content panels — one visible at a time via code -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- ITEMS tab: 4-column grid -->
        <GridView
            android:id="@+id/gridCollection"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:numColumns="4"
            android:horizontalSpacing="8dp"
            android:verticalSpacing="8dp"
            android:padding="12dp"
            android:stretchMode="columnWidth"
            android:visibility="visible" />

        <!-- SETS tab: scrollable list of set cards -->
        <ScrollView
            android:id="@+id/scrollSets"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/containerSets"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp" />

        </ScrollView>

    </FrameLayout>

</LinearLayout>
