<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D1A0D">

    <!-- Top bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#0a140a"
        android:paddingStart="8dp"
        android:paddingEnd="16dp">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BACK"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:backgroundTint="@android:color/transparent"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SHOP"
            android:textSize="22sp"
            android:textColor="#4CAF50"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_centerInParent="true" />

        <TextView
            android:id="@+id/tvCoinBalance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● 0"
            android:textSize="14sp"
            android:textColor="#F5C542"
            android:fontFamily="monospace"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true" />

    </RelativeLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1E3A1E" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!-- CARD 1: O2 CAPACITY                                            -->
            <!-- ═══════════════════════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_upgrade_card"
                android:padding="14dp"
                android:layout_marginBottom="8dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="O2 CAPACITY"
                        android:textColor="#E0E0E0"
                        android:textSize="14sp"
                        android:fontFamily="monospace"
                        android:textStyle="bold"
                        android:layout_centerVertical="true"
                        android:layout_alignParentStart="true" />

                    <TextView
                        android:id="@+id/tvLevelOxygen"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LVL 1/5"
                        android:textColor="#F5C542"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:layout_centerVertical="true"
                        android:layout_alignParentEnd="true" />

                </RelativeLayout>

                <LinearLayout
                    android:id="@+id/pipsOxygen"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <View android:layout_width="28dp" android:layout_height="8dp" android:background="#1A2E1A" android:layout_marginEnd="4dp" />
                    <View android:layout_width="28dp" android:layout_height="8dp" android:background="#1A2E1A" android:layout_marginEnd="4dp" />
                    <View android:layout_width="28dp" android:layout_height="8dp" android:background="#1A2E1A" android:layout_marginEnd="4dp" />
                    <View android:layout_width="28dp" android:layout_height="8dp" android:background="#1A2E1A" android:layout_marginEnd="4dp" />
                    <View android:layout_width="28dp" android:layout_height="8dp" android:background="#1A2E1A" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Increases maximum oxygen tank size"
                    android:textColor="#666666"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="10dp" />

                <Button
                    android:id="@+id/btnUpgradeOxygen"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:text="UPGRADE  ● 100"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:backgroundTint="#2B6B2B"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />

            </LinearLayout>

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!-- CARD 2: STEER SPEED                                            -->
            <!-- ═══════════════════════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_upgrade_card"
                android:padding="14dp"
                android:layout_marginBottom="8dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="STEER SPEED"
                        android:textColor="#E0E0E0"
                        android:textSize="14sp"
                        android:fontFamily="monospace"
                        android:textStyle="bold"
                        android:layout_centerVertical="true"
                        android:layout_alignParentStart="true" />

                    <TextView
                        android:id="@+id/tvLevelSteer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LVL 1/5"
                        android:textColor="#F5C542"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:layout_centerVertical="true"
                        android:layout_alignParentEnd="true" />

                </RelativeLayout>

                <LinearLayout
                    android:id="@+id/pipsSteer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <View android:layout_width="28dp" android:layout_height="8dp" android:background="#1A2E1A" android:layout_marginEnd="4dp" />
                    <View android:layout_width="28dp" android:layout_height="8dp" android:background="#1A2E1A" android:layout_marginEnd="4dp" />
                    <View android:layout_width="28dp" android:layout_height="8dp" android:background="#1A2E1A" android:layout_marginEnd="4dp" />
                    <View android:layout_width="28dp" android:layout_height="8dp" android:background="#1A2E1A" android:layout_marginEnd="4dp" />
                    <View android:layout_width="28dp" android:layout_height="8dp" android:background="#1A2E1A" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Turn faster while digging"
                    android:textColor="#666666"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="10dp" />

                <Button
                    android:id="@+id/btnUpgradeSteer"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:text="UPGRADE  ● 100"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:backgroundTint="#2B6B2B"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />

            </LinearLayout>

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!-- CARD 3: DIG SPEED                                              -->
            <!-- ═══════════════════════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_upgrade_card"
                android:padding="14dp"
                android:layout_marginBottom="8dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DIG SPEED"
                        android:textColor="#E0E0E0"
                        android:textSize="14sp"
                        android:fontFamily="monospace"
                        android:textStyle="bold"
                        android:layout_centerVertical="true"
                        android:layout_alignParentStart="true" />

                    <TextView
                        android:id="@+id/tvLevelDig"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LVL 1/5"
                        android:textColor="#F5C542"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:layout_centerVertical="true"
                        android:layout_alignParentEnd="true" />

                </RelativeLayout>

                <LinearLayout
                    android:id="@+id/pipsDig"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <View android:layout_width="28dp" android:layout_height="8dp" android:background="#1A2E1A" android:layout_marginEnd="4dp" />
                    <View android:layout_width="28dp" android:layout_height="8dp" android:background="#1A2E1A" android:layout_marginEnd="4dp" />
                    <View android:layout_width="28dp" android:layout_height="8dp" android:background="#1A2E1A" android:layout_marginEnd="4dp" />
                    <View android:layout_width="28dp" android:layout_height="8dp" android:background="#1A2E1A" android:layout_marginEnd="4dp" />
                    <View android:layout_width="28dp" android:layout_height="8dp" android:background="#1A2E1A" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Dig through soil faster"
                    android:textColor="#666666"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="10dp" />

                <Button
                    android:id="@+id/btnUpgradeDig"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:text="UPGRADE  ● 100"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:backgroundTint="#2B6B2B"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />

            </LinearLayout>

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!-- CARD 4: COLLECTION RANGE                                       -->
            <!-- ═══════════════════════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_upgrade_card"
                android:padding="14dp"
                android:layout_marginBottom="8dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="COLLECTION RANGE"
                        android:textColor="#E0E0E0"
                        android:textSize="14sp"
                        android:fontFamily="monospace"
                        android:textStyle="bold"
                        android:layout_centerVertical="true"
                        android:layout_alignParentStart="true" />

                    <TextView
                        android:id="@+id/tvLevelRange"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LVL 1/5"
                        android:textColor="#F5C542"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:layout_centerVertical="true"
                        android:layout_alignParentEnd="true" />

                </RelativeLayout>

                <LinearLayout
                    android:id="@+id/pipsRange"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <View android:layout_width="28dp" android:layout_height="8dp" android:background="#1A2E1A" android:layout_marginEnd="4dp" />
                    <View android:layout_width="28dp" android:layout_height="8dp" android:background="#1A2E1A" android:layout_marginEnd="4dp" />
                    <View android:layout_width="28dp" android:layout_height="8dp" android:background="#1A2E1A" android:layout_marginEnd="4dp" />
                    <View android:layout_width="28dp" android:layout_height="8dp" android:background="#1A2E1A" android:layout_marginEnd="4dp" />
                    <View android:layout_width="28dp" android:layout_height="8dp" android:background="#1A2E1A" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Pick up items from further away"
                    android:textColor="#666666"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="10dp" />

                <Button
                    android:id="@+id/btnUpgradeRange"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:text="UPGRADE  ● 100"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:backgroundTint="#2B6B2B"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />

            </LinearLayout>

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!-- CARD 5: O2 REFILL                                              -->
            <!-- ═══════════════════════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_upgrade_card"
                android:padding="14dp"
                android:layout_marginBottom="8dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="O2 REFILL"
                        android:textColor="#E0E0E0"
                        android:textSize="14sp"
                        android:fontFamily="monospace"
                        android:textStyle="bold"
                        android:layout_centerVertical="true"
                        android:layout_alignParentStart="true" />

                    <TextView
                        android:id="@+id/tvLevelRefill"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LVL 1/5"
                        android:textColor="#F5C542"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:layout_centerVertical="true"
                        android:layout_alignParentEnd="true" />

                </RelativeLayout>

                <LinearLayout
                    android:id="@+id/pipsRefill"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <View android:layout_width="28dp" android:layout_height="8dp" android:background="#1A2E1A" android:layout_marginEnd="4dp" />
                    <View android:layout_width="28dp" android:layout_height="8dp" android:background="#1A2E1A" android:layout_marginEnd="4dp" />
                    <View android:layout_width="28dp" android:layout_height="8dp" android:background="#1A2E1A" android:layout_marginEnd="4dp" />
                    <View android:layout_width="28dp" android:layout_height="8dp" android:background="#1A2E1A" android:layout_marginEnd="4dp" />
                    <View android:layout_width="28dp" android:layout_height="8dp" android:background="#1A2E1A" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Each canister restores more oxygen"
                    android:textColor="#666666"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="10dp" />

                <Button
                    android:id="@+id/btnUpgradeRefill"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:text="UPGRADE  ● 100"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:backgroundTint="#2B6B2B"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />

            </LinearLayout>

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!-- CARD 6: CLAW LEVEL                                             -->
            <!-- ═══════════════════════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_upgrade_card"
                android:padding="14dp"
                android:layout_marginBottom="8dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CLAW LEVEL"
                        android:textColor="#E0E0E0"
                        android:textSize="14sp"
                        android:fontFamily="monospace"
                        android:textStyle="bold"
                        android:layout_centerVertical="true"
                        android:layout_alignParentStart="true" />

                    <TextView
                        android:id="@+id/tvLevelClaw"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LVL 1/5"
                        android:textColor="#F5C542"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:layout_centerVertical="true"
                        android:layout_alignParentEnd="true" />

                </RelativeLayout>

                <LinearLayout
                    android:id="@+id/pipsClaw"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <View android:layout_width="28dp" android:layout_height="8dp" android:background="#1A2E1A" android:layout_marginEnd="4dp" />
                    <View android:layout_width="28dp" android:layout_height="8dp" android:background="#1A2E1A" android:layout_marginEnd="4dp" />
                    <View android:layout_width="28dp" android:layout_height="8dp" android:background="#1A2E1A" android:layout_marginEnd="4dp" />
                    <View android:layout_width="28dp" android:layout_height="8dp" android:background="#1A2E1A" android:layout_marginEnd="4dp" />
                    <View android:layout_width="28dp" android:layout_height="8dp" android:background="#1A2E1A" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Stronger claws for tougher soil"
                    android:textColor="#666666"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="10dp" />

                <Button
                    android:id="@+id/btnUpgradeClaw"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:text="UPGRADE  ● 100"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:backgroundTint="#2B6B2B"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />

            </LinearLayout>

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!-- CARD 7: RARITY BOOST                                           -->
            <!-- ═══════════════════════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_upgrade_card"
                android:padding="14dp"
                android:layout_marginBottom="8dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RARITY BOOST"
                        android:textColor="#E0E0E0"
                        android:textSize="14sp"
                        android:fontFamily="monospace"
                        android:textStyle="bold"
                        android:layout_centerVertical="true"
                        android:layout_alignParentStart="true" />

                    <TextView
                        android:id="@+id/tvLevelRarity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LVL 1/5"
                        android:textColor="#F5C542"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:layout_centerVertical="true"
                        android:layout_alignParentEnd="true" />

                </RelativeLayout>

                <LinearLayout
                    android:id="@+id/pipsRarity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <View android:layout_width="28dp" android:layout_height="8dp" android:background="#1A2E1A" android:layout_marginEnd="4dp" />
                    <View android:layout_width="28dp" android:layout_height="8dp" android:background="#1A2E1A" android:layout_marginEnd="4dp" />
                    <View android:layout_width="28dp" android:layout_height="8dp" android:background="#1A2E1A" android:layout_marginEnd="4dp" />
                    <View android:layout_width="28dp" android:layout_height="8dp" android:background="#1A2E1A" android:layout_marginEnd="4dp" />
                    <View android:layout_width="28dp" android:layout_height="8dp" android:background="#1A2E1A" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Better chance of finding rare items"
                    android:textColor="#666666"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="10dp" />

                <Button
                    android:id="@+id/btnUpgradeRarity"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:text="UPGRADE  ● 100"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:backgroundTint="#2B6B2B"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
